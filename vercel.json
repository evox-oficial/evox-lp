{
    "cleanUrls": true,
    "trailingSlash": false,
    "buildCommand": "npm run build",
    "headers": [
        {
            "source": "/(.*)\\.(jpg|jpeg|png|webp|avif|gif|svg|ico)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
            ]
        },
        {
            "source": "/(css|js)/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ]
}
